# data-redactor 環境変数（.env.example）
#
# ★ 実際に設定が要るのは下の RESOURCE_NAME_GPT41_MINI だけ（LLM 検出を使う場合）。
#   それ以外は既定値で動くので、変えたいときだけ該当行のコメントを外して上書きする。
#   LLM を使わない（UI＋NER＋辞書のみ）なら、空の .env でも起動する。

# LLM 検出（pii-masker / Azure OpenAI）を使うなら必須: Azure リソース名。
# エンドポイント https://<ここ>.openai.azure.com になる。
# 認証情報はここには書かない（ホストで az login し compose の ~/.azure マウントで渡す。WSL/Linux 側で az login）。
RESOURCE_NAME_GPT41_MINI=

# ===== 以下はすべて任意（既定で動く）。必要なときだけコメントを外す =====

# UI（Streamlit）が接続するマスキング API の URL。既定は同一ホストの 127.0.0.1:8509。
#   ローカルで `data-redactor dev` / `serve`+`ui` を使うなら既定のままでよい。
#   Docker compose では api サービスを指すよう compose 側で自動設定される
#   （MASK_API_URL=http://data-redactor-api:8509）ので、ここで設定する必要はない。
# MASK_API_URL=http://127.0.0.1:8509

# UI から API への 1 リクエストのタイムアウト秒数。既定 600 秒。
#   大きい文書の NER は重い（数分〜十数分）ので、タイムアウトが出るなら伸ばす。
#   0 を指定すると無制限（完了まで待ち続ける）。空・不正値は既定 600 秒。
# MASK_API_TIMEOUT=600

# Azure 認証で試す資格情報の種類（LLM 検出の「初回だけ異常に遅い」対策）。
#   未設定だと DefaultAzureCredential が全種類を順に試し、ローカル PC では
#   ManagedIdentityCredential の IMDS プローブ（169.254.169.254 への到達待ち）で
#   初回に数百秒かかることがある（2 回目以降はトークンがキャッシュされ速い）。
#   ローカル（az login 運用）は dev にすると開発用資格情報だけを試して初回が速い。
#   Docker/Azure でマネージド ID を使うなら prod（または未設定）にする。
#   値: dev（開発用＝CLI/VSCode 等）／ prod（本番用＝環境変数/ワークロード/マネージド ID）
#       ／ 特定名（例 AzureCliCredential）。
# AZURE_TOKEN_CREDENTIALS=dev

# kb-mcp の接続先（kb-mcp ソースを使う場合のみ。既定値は下記）。
# KB_MCP_URL=http://localhost:8000/mcp

# LLM 既定モデル（client.py が対応するのは gpt-4.1-mini のみ）。
# DEFAULT_LLM_MODEL=gpt-4.1-mini

# LLM 窓ポリシー（チューニング用。変えると LLM 検出キャッシュが自動で無効化＝再検出）。
# LLM_WINDOW_MAX_TOKENS=15000
# LLM_WINDOW_OVERLAP_TOKENS=0

# LLM 検出の対象プリセット（pii-masker の target）。既定 all。変えると検出キャッシュが自動で無効化＝再検出。
#   all … 人名/社名/商標の調教済み3種（高精度・既定。マスク対象がこの3種）。
#   pii … 従来の全type汎用（地名/連絡先/ID も拾うが精度はやや落ちる・単一プロンプト）。
# LLM_DETECT_TARGET=all

# LLM 検出の 429（Azure 一時混雑）止血パラメータ。既定で動く。混雑が激しいときだけ調整。
#   MAX_RETRIES … 窓ごとの検出をリトライする最大回数（既定 5）。
#   RETRY_BASE_WAIT … 指数バックオフの基数・秒（Retry-After があればそちら優先。既定 2.0）。
#   WINDOW_THROTTLE … 窓ごとの検出前に挟む待機・秒（連射を均す。0 で無効。既定 0.5）。
# LLM_DETECT_MAX_RETRIES=5
# LLM_DETECT_RETRY_BASE_WAIT=2.0
# LLM_DETECT_WINDOW_THROTTLE=0.5

# LLM 検出の進捗ログ（窓 i/n・所要時間・429 リトライ待機・エラーを stderr へ）。既定 ON。
# 「窓 1/5 で進まない」ときの切り分け用。うるさければ 0 で無効化。
# LLM_DETECT_LOG=1
